{
  "name": "debug_router",
  "license": "Apache-2.0",
  "devDependencies": {},
  "repository": "https://github.com/lynx-family/lynx",
  "author": "lynx",
  "description": "A Powerful Cross-Platform Framework that builds native Apps with Web technologies",
  "main": "",
  "scripts": {
    "prepare": "../../../.venv/bin/python3 ./script/build.py --sync --verbose",
    "dev": "../../../.venv/bin/python3 ./script/build.py --is_debug --verbose",
    "build": "../../../.venv/bin/python3 ./script/build.py --is_debug --build_hap --sync --verbose",
    "build:release": "../../../.venv/bin/python3 ./script/build.py --build_hap --sync --verbose",
  },
  "version": "0.0.1",
  "dependencies": {
    "@lynx/vmsdk": "0.0.2-alpha.1029-cqtest"
  },
  "dynamicDependencies": {},
  "parameterFile": "./parameter.json",
  "overrides": {
    "@lynx/lynx": "file:./lynx",
    "@lynx/lynx_devtool": "file:./lynx_devtool",
    "@lynx/lynx_devtool_service": "file:./lynx_services/lynx_devtool_service",
  },
  "modelVersion": "5.0.0"
}
